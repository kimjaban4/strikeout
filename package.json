{
  "name": "mount-psycho-baseball",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "split:js": "node tools/split-game-modules.mjs",
    "check:structure": "node tools/check-project-structure.mjs",
    "build:deploy": "node tools/build-deploy.mjs",
    "build:pages": "node tools/build-pages.mjs",
    "check:deploy": "node tools/check-deploy-sync.mjs",
    "check:pages": "node tools/check-pages.mjs",
    "verify": "npm run build:deploy && npm run test:smoke",
    "verify:pages": "npm run build:pages && npm run test:smoke",
    "balance:sim": "node tools/balance-sim.mjs",
    "balance:sim:100": "node tools/balance-sim.mjs --games 100 --bot player --runs-dir balance-reports/runs-player",
    "balance:sim:100:smart": "node tools/balance-sim.mjs --games 100 --bot player --runs-dir balance-reports/runs-player-smart",
    "balance:sim:3k": "node tools/balance-sim.mjs --games 3000 --max-pitches 320",
    "balance:aggregate": "node tools/balance-aggregate.mjs",
    "check:pitcher-card": "playwright test -g \"투수 카드\"",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
